{
  "name": "e2e-tests",
  "version": "1.0.0",
  "description": "ERP System E2E Tests with Playwright",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:login": "playwright test tests/login.spec.ts",
    "test:products": "playwright test tests/products.spec.ts",
    "test:inventory": "playwright test tests/inventory.spec.ts",
    "test:sales": "playwright test tests/sales.spec.ts",
    "test:finance": "playwright test tests/finance.spec.ts",
    "test:reports": "playwright test tests/reports.spec.ts",
    "test:customers": "playwright test tests/customers.spec.ts",
    "test:specs": "playwright test tests/specs.spec.ts",
    "report": "playwright show-report",
    "codegen": "playwright codegen http://localhost:5173"
  },
  "keywords": ["playwright", "e2e", "testing", "erp"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3"
  }
}
